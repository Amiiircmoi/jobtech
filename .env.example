# ─────────────────────────────────────────────────────────────
# jobtech — variables d'environnement (modèle)
# Copier en `.env` et renseigner les vraies valeurs. NE JAMAIS commiter `.env`.
# Générer une SECRET_KEY (ÉVITER le caractère '$' : interprété par docker compose) :
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'-_=+%@!*') for _ in range(60)))"
# ─────────────────────────────────────────────────────────────

# --- Django API ---
DJANGO_SECRET_KEY=change-me-generate-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Mettre à True UNIQUEMENT derrière un vrai terminateur TLS (VPS/reverse-proxy) :
DJANGO_SECURE_SSL_REDIRECT=False

# --- PostgreSQL (Data Warehouse + lecture API) ---
POSTGRES_DB=jobtech
POSTGRES_USER=jobtech
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# URL consommée par Django et l'ETL (doit refléter les valeurs ci-dessus)
DATABASE_URL=postgres://jobtech:change-me@localhost:5432/jobtech

# --- Sources externes (ETL) — optionnel, le générateur synthétique ne les requiert pas ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

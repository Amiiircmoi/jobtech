# Copier en deploy/.env (JAMAIS commité) et renseigner.

# Domaine pointant (DNS A/AAAA) vers l'IP du VPS — Caddy y obtient le certificat TLS.
DOMAIN=jobtech.exemple.com

# Secret Django — générer SANS '$' (interprété par docker compose) :
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'-_=+%@!*') for _ in range(60)))"
DJANGO_SECRET_KEY=change-me-sans-dollar

# PostgreSQL (mot de passe fort)
POSTGRES_DB=jobtech
POSTGRES_USER=jobtech
POSTGRES_PASSWORD=change-me-strong

# Sources externes (optionnel ; la démo utilise des données synthétiques)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
